            "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>🎨 动漫绘画板</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif;\n      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);\n      min-height: 100vh;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      padding: 20px;\n      color: #fff;\n    }\n    h1 {\n      font-size: 2rem;\n      margin-bottom: 10px;\n      background: linear-gradient(90deg, #e94560, #ff6b6b, #feca57);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      text-shadow: 0 0 30px rgba(233, 69, 96, 0.3);\n    }\n    .toolbar {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 12px;\n      align-items: center;\n      margin-bottom: 15px;\n      padding: 15px 20px;\n      background: rgba(255,255,255,0.08);\n      border-radius: 16px;\n      backdrop-filter: blur(10px);\n    }\n    .tool-group {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      padding: 6px 12px;\n      background: rgba(0,0,0,0.2);\n      border-radius: 10px;\n    }\n    .tool-group label {\n      font-size: 0.85rem;\n      color: #a0a0c0;\n    }\n    button {\n      padding: 10px 18px;\n      border: none;\n      border-radius: 10px;\n      cursor: pointer;\n      font-size: 0.95rem;\n      font-weight: 600;\n      transition: all 0.2s;\n      display: flex;\n      align-items: center;\n      gap: 6px;\n    }\n    button:hover { transform: translateY(-2px); }\n    button:active { transform: translateY(0); }\n    .btn-pen { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }\n    .btn-eraser { background: linear-gradient(135deg, #f093fb, #f5576c); color: #fff; }\n    .btn-clear { background: linear-gradient(135deg, #ff6b6b, #ee5a24); color: #fff; }\n    .btn-save { background: linear-gradient(135deg, #00b894, #00cec9); color: #fff; }\n    .btn-active { box-shadow: 0 0 0 3px rgba(255,255,255,0.4); }\n    input[type=\"color\"] {\n      width: 40px; height: 40px; border: none; border-radius: 50%;\n      cursor: pointer; background: none;\n    }\n    input[type=\"range\"] {\n      width: 120px; cursor: pointer;\n    }\n    .canvas-container {\n      position: relative;\n      border-radius: 16px;\n      overflow: hidden;\n      box-shadow: 0 20px 60px rgba(0,0,0,0.4);\n    }\n    canvas {\n      display: block;\n      background: #fff;\n      cursor: crosshair;\n    }\n    .brush-preview {\n      width: 30px; height: 30px;\n      border-radius: 50%;\n      border: 2px solid rgba(255,255,255,0.3);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: rgba(0,0,0,0.2);\n    }\n    .brush-dot {\n      border-radius: 50%;\n      background: currentColor;\n    }\n    .size-display {\n      font-size: 0.8rem;\n      color: #a0a0c0;\n      min-width: 30px;\n    }\n  </style>\n</head>\n<body>\n  <h1>🎨 动漫绘画板</h1>\n\n  <div class=\"toolbar\">\n    <div class=\"tool-group\">\n      <button class=\"btn-pen btn-active\" id=\"penBtn\" title=\"画笔\">✏️ 画笔</button>\n      <button class=\"btn-eraser\" id=\"eraserBtn\" title=\"橡皮擦\">🧹 橡皮擦</button>\n    </div>\n\n    <div class=\"tool-group\">\n      <label>颜色</label>\n      <input type=\"color\" id=\"colorPicker\" value=\"#000000\">\n      <div class=\"brush-preview\" id=\"brushPreview\">\n        <div class=\"brush-dot\" id=\"brushDot\" style=\"width:4px;height:4px;color:#000;\"></div>\n      </div>\n    </div>\n\n    <div class=\"tool-group\">\n      <label>粗细</label>\n      <input type=\"range\" id=\"brushSize\" min=\"1\" max=\"50\" value=\"4\">\n      <span class=\"size-display\" id=\"sizeValue\">4</span>\n    </div>\n\n    <div class=\"tool-group\">\n      <button class=\"btn-clear\" id=\"clearBtn\" title=\"清空画布\">🗑️ 清空</button>\n      <button class=\"btn-save\" id=\"saveBtn\" title=\"保存作品\">💾 保存</button>\n    </div>\n  </div>\n\n  <div class=\"canvas-container\">\n    <canvas id=\"canvas\" width=\"900\" height=\"600\"></canvas>\n  </div>\n\n  <script>\n    const canvas = document.getElementById('canvas');\n    const ctx = canvas.getContext('2d');\n    let painting = false;\n    let isEraser = false;\n    let brushSize = 4;\n    let brushColor = '#000000';\n\n    // 初始化画布为白色背景\n    ctx.fillStyle = '#ffffff';\n    ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n    function getPos(e) {\n      const rect = canvas.getBoundingClientRect();\n      return {\n        x: e.clientX - rect.left,\n        y: e.clientY - rect.top\n      };\n    }\n\n    function startDraw(e) {\n      painting = true;\n      draw(e);\n    }\n\n    function endDraw() {\n      painting = false;\n      ctx.beginPath();\n    }\n\n    function draw(e) {\n      if (!painting) return;\n      const pos = getPos(e);\n      ctx.lineWidth = brushSize;\n      ctx.lineCap = 'round';\n      ctx.lineJoin = 'round';\n      ctx.strokeStyle = isEraser ? '#ffffff' : brushColor;\n      ctx.lineTo(pos.x, pos.y);\n      ctx.stroke();\n      ctx.beginPath();\n      ctx.moveTo(pos.x, pos.y);\n    }\n\n    // 鼠标事件\n    canvas.addEventListener('mousedown', startDraw);\n    canvas.addEventListener('mouseup', endDraw);\n    canvas.addEventListener('mousemove', draw);\n    canvas.addEventListener('mouseleave', endDraw);\n\n    // 触摸事件（支持平板/手机）\n    canvas.addEventListener('touchstart', (e) => {\n      e.preventDefault();\n      const touch = e.touches[0];\n      const mouseEvent = new MouseEvent('mousedown', {\n        clientX: touch.clientX, clientY: touch.clientY\n      });\n      canvas.dispatchEvent(mouseEvent);\n    });\n    canvas.addEventListener('touchend', () => {\n      const mouseEvent = new MouseEvent('mouseup', {});\n      canvas.dispatchEvent(mouseEvent);\n    });\n    canvas.addEventListener('touchmove', (e) => {\n      e.preventDefault();\n      const touch = e.touches[0];\n      const mouseEvent = new MouseEvent('mousemove', {\n        clientX: touch.clientX, clientY: touch.clientY\n      });\n      canvas.dispatchEvent(mouseEvent);\n    });\n\n    // 工具按钮\n    const penBtn = document.getElementById('penBtn');\n    const eraserBtn = document.getElementById('eraserBtn');\n    const colorPicker = document.getElementById('colorPicker');\n    const brushSizeSlider = document.getElementById('brushSize');\n    const sizeValue = document.getElementById('sizeValue');\n    const brushDot = document.getElementById('brushDot');\n    const clearBtn = document.getElementById('clearBtn');\n    const saveBtn = document.getElementById('saveBtn');\n\n    penBtn.addEventListener('click', () => {\n      isEraser = false;\n      penBtn.classList.add('btn-active');\n      eraserBtn.classList.remove('btn-active');\n    });\n\n    eraserBtn.addEventListener('click', () => {\n      isEraser = true;\n      eraserBtn.classList.add('btn-active');\n      penBtn.classList.remove('btn-active');\n    });\n\n    colorPicker.addEventListener('input', (e) => {\n      brushColor = e.target.value;\n      brushDot.style.color = brushColor;\n      brushDot.style.width = brushSize + 'px';\n      brushDot.style.height = brushSize + 'px';\n    });\n\n    brushSizeSlider.addEventListener('input', (e) => {\n      brushSize = parseInt(e.target.value);\n      sizeValue.textContent = brushSize;\n      brushDot.style.width = Math.min(brushSize, 20) + 'px';\n      brushDot.style.height = Math.min(brushSize, 20) + 'px';\n    });\n\n    clearBtn.addEventListener('click', () => {\n      if (confirm('确定要清空画布吗？')) {\n        ctx.fillStyle = '#ffffff';\n        ctx.fillRect(0, 0, canvas.width, canvas.height);\n      }\n    });\n\n    saveBtn.addEventListener('click', () => {\n      const link = document.createElement('a');\n      link.download = '动漫作品_' + new Date().toISOString().slice(0,10) + '.png';\n      link.href = canvas.toDataURL('image/png');\n      link.click();\n    });\n  </script>\n</body>\n</html>\n"
