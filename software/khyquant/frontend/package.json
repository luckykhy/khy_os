{
  "name": "quant-trading-frontend",
  "version": "1.0.0",
  "description": "基于Vue和Agent的量化交易系统 - Vue前端",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --open",
    "dev-no-browser": "vite --host 0.0.0.0",
    "dev-auto-port": "vite --host 0.0.0.0 --open",
    "build": "vite build",
    "mobile:sync": "npm run build && npx cap sync android",
    "mobile:open:android": "npm run mobile:sync && npx cap open android",
    "mobile:run:android": "npm run mobile:sync && npx cap run android",
    "mobile:apk:debug": "npm run mobile:sync && cd android && ./gradlew assembleDebug",
    "mobile:apk:release": "npm run mobile:sync && cd android && ./gradlew assembleRelease",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.5",
    "dompurify": "^3.4.2",
    "element-plus": "^2.5.4",
    "highlight.js": "^11.11.1",
    "lightweight-charts": "^4.1.3",
    "marked": "^18.0.3",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.3",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.3",
    "eslint": "^9.17.0",
    "sass": "^1.69.7",
    "terser": "^5.46.0",
    "typescript": "^5.7.0",
    "vite": "^5.0.11",
    "vite-plugin-pwa": "^1.3.0"
  }
}
