{
  "name": "khy-os-backend",
  "version": "1.1.7",
  "description": "Khy OS AI platform backend with default app runtime",
  "main": "server.js",
  "bin": {
    "khyquant": "./bin/khy.js",
    "khy-os": "./bin/khy.js",
    "khy": "./bin/khy.js"
  },
  "files": [
    "bin/khy.js",
    "bin/khy-os-init.js",
    "src/",
    "config/",
    "scripts/",
    "sql/",
    "migrations/",
    "assets/",
    "akshare_scripts/",
    "wasm-chain/",
    "wasm-context/",
    "wasm-indicators/",
    "vendor/",
    "_source/",
    "server.js",
    "setup.js",
    "start-with-db.js",
    "check-env.js",
    "reset-database.js",
    "create-test-users.js",
    "test-db-connection.js",
    "inference_server.py",
    "babel.config.json",
    "esbuild.config.js",
    "jsconfig.json",
    "README*"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:db": "node start-with-db.js",
    "migrate": "node src/migrations/run.js",
    "arch:debt": "node scripts/archDebtScan.js",
    "arch:debt:baseline": "node scripts/archDebtScan.js --update-baseline",
    "arch:god": "node scripts/archDebtScan.js --god-report",
    "test": "jest",
    "test:node": "node --test $(grep -rl \"require('node:test')\" tests | tr '\\n' ' ')",
    "test:all": "npm test && npm run test:node",
    "test:summary": "node scripts/test-summary.js",
    "test:tui": "node scripts/run-ink-tui-tests.js",
    "test-db": "node test-db-connection.js",
    "check-env": "node check-env.js",
    "reset-db": "node reset-database.js",
    "create-users": "node create-test-users.js",
    "seed": "node scripts/seed.js",
    "cli": "node bin/khy.js",
    "setup": "node setup.js",
    "prepack": "node scripts/prepack.js"
  },
  "keywords": [
    "ai-os",
    "agent-platform",
    "express",
    "postgresql"
  ],
  "author": "孔浩原",
  "license": "LicenseRef-Source-Available",
  "homepage": "https://github.com/kodehu03/khy-os#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kodehu03/khy-os.git"
  },
  "bugs": {
    "url": "https://github.com/kodehu03/khy-os/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "@aws/codewhisperer-streaming-client": "^1.0.45",
    "@babel/preset-react": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@khy/shared": "file:./vendor/shared",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/instrumentation-express": "^0.56.0",
    "@opentelemetry/instrumentation-http": "^0.207.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.207.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@simplewebauthn/server": "^13.3.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.0.0",
    "iconv-lite": "^0.4.24",
    "ink": "^6.8.0",
    "inquirer": "^8.2.7",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-stream-zip": "^1.15.0",
    "ora": "^5.4.1",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-devtools-core": "^6.1.5",
    "redis": "^4.7.1",
    "sequelize": "^6.35.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.29.7",
    "javascript-obfuscator": "^5.4.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "optionalDependencies": {
    "glob": "^10.3.10",
    "https-proxy-agent": "^7.0.4",
    "node-llama-cpp": "^3.18.1",
    "node-pty": "^1.0.0",
    "string-width": "^5.1.2"
  }
}
