    {
      "name": "Open-Meteo",
      "category": "weather",
      "description": "Free weather forecast API, no key required",
      "desc_zh": "免费天气预报 — 全球城市当前温度、3天预报、降水概率",
      "usage": ["北京天气", "上海明天下雨吗", "深圳气温"],
      "base": "https://api.open-meteo.com/v1/forecast",
      "example": "?latitude=39.9&longitude=116.4&current_weather=true",
      "docs": "https://open-meteo.com/en/docs",
      "auth": "none",
      "cors": true
    },
