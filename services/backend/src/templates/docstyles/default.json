    "title":    { "ascii": "SimHei", "eastAsia": "黑体", "size": 22, "sizeLabel": "二号", "bold": true, "align": "center", "spaceBefore": 0, "spaceAfter": 18 },
    "heading1": { "ascii": "SimHei", "eastAsia": "黑体", "size": 16, "sizeLabel": "三号", "bold": true, "align": "center", "spaceBefore": 12, "spaceAfter": 12, "pageBreakBefore": false },
    "heading2": { "ascii": "SimHei", "eastAsia": "黑体", "size": 14, "sizeLabel": "四号", "bold": true, "align": "left", "spaceBefore": 12, "spaceAfter": 6 },
    "heading3": { "ascii": "SimHei", "eastAsia": "黑体", "size": 12, "sizeLabel": "小四", "bold": true, "align": "left", "spaceBefore": 6, "spaceAfter": 6 },
    "heading4": { "ascii": "SimHei", "eastAsia": "黑体", "size": 12, "sizeLabel": "小四", "bold": true, "align": "left", "spaceBefore": 6, "spaceAfter": 6 },
    "quote":    { "ascii": "Times New Roman", "eastAsia": "楷体", "size": 12, "sizeLabel": "小四", "italic": false, "indentChars": 2, "color": "404040" },
    "code":     { "ascii": "Consolas", "eastAsia": "宋体", "size": 10.5, "sizeLabel": "五号", "color": "1A1A1A" },
    "caption":  { "ascii": "Times New Roman", "eastAsia": "宋体", "size": 10.5, "sizeLabel": "五号", "align": "center", "italic": false },
    "reference":{ "ascii": "Times New Roman", "eastAsia": "宋体", "size": 10.5, "sizeLabel": "五号", "hangingIndentChars": 2 },
    "list":     { "ascii": "Times New Roman", "eastAsia": "宋体", "size": 12, "sizeLabel": "小四" },
    "tableCell":{ "ascii": "Times New Roman", "eastAsia": "宋体", "size": 10.5, "sizeLabel": "五号" }
